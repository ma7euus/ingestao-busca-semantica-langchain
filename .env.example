# Copie este arquivo para .env e preencha a chave do provedor escolhido.

# Provedor padrao: openai. Use gemini para usar Google Gemini.
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5-nano

# Gemini / Google Generative AI
GOOGLE_API_KEY=
GEMINI_EMBEDDING_MODEL=models/embedding-001
GEMINI_LLM_MODEL=gemini-2.5-flash-lite

# PostgreSQL + pgVector
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/langchain
COLLECTION_NAME=document_pdf

# Ingestao e busca
PDF_PATH=document.pdf
SEARCH_K=10
RECREATE_COLLECTION=true
